{
  "name": "espalier",
  "private": true,
  "license": "Apache-2.0",
  "author": "Ryan Murphy",
  "repository": {
    "type": "git",
    "url": "https://github.com/ryanmurf/espalier.git"
  },
  "bugs": {
    "url": "https://github.com/ryanmurf/espalier/issues"
  },
  "homepage": "https://github.com/ryanmurf/espalier#readme",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest",
    "test:node": "vitest",
    "test:bun": "bun run vitest",
    "test:deno": "deno run --allow-read --allow-net --allow-env --allow-sys npm:vitest",
    "clean": "pnpm -r clean",
    "size": "size-limit",
    "size:report": "size-limit --json",
    "benchmark": "node benchmarks/run.mjs",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "better-sqlite3"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@size-limit/file": "^12.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "size-limit": "^12.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
