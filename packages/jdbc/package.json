{
  "name": "espalier-jdbc",
  "version": "2.0.0",
  "description": "JDBC-like unified database driver abstraction for TypeScript",
  "license": "Apache-2.0",
  "author": "Ryan Murphy",
  "repository": {
    "type": "git",
    "url": "https://github.com/ryanmurf/espalier.git",
    "directory": "packages/jdbc"
  },
  "bugs": {
    "url": "https://github.com/ryanmurf/espalier/issues"
  },
  "homepage": "https://github.com/ryanmurf/espalier#readme",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "tsup": "^8.4.0"
  }
}
