{
  "name": "espalier-jdbc-pg",
  "version": "1.11.0",
  "description": "PostgreSQL driver adapter for espalier-jdbc",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "espalier-jdbc": "workspace:*"
  },
  "peerDependencies": {
    "pg": "^8.0.0",
    "pg-cursor": "^2.0.0"
  },
  "peerDependenciesMeta": {
    "pg": {
      "optional": true
    },
    "pg-cursor": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/pg": "^8.11.11",
    "@types/pg-cursor": "^2.7.2",
    "espalier-data": "workspace:*",
    "pg": "^8.13.1",
    "pg-cursor": "^2.17.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.3"
  }
}
