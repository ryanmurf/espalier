{
  "name": "espalier-jdbc-pg",
  "version": "0.1.0",
  "description": "PostgreSQL driver adapter for espalier-jdbc",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "espalier-jdbc": "workspace:*"
  },
  "peerDependencies": {
    "pg": "^8.0.0"
  },
  "devDependencies": {
    "espalier-data": "workspace:*",
    "typescript": "^5.7.3",
    "tsup": "^8.4.0",
    "@types/pg": "^8.11.11",
    "pg": "^8.13.1"
  }
}
