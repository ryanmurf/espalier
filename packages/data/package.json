{
  "name": "espalier-data",
  "version": "1.10.0",
  "description": "Spring Data Relational-like repository and entity mapping layer for TypeScript",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./core": {
      "import": {
        "types": "./dist/core.d.ts",
        "default": "./dist/core.js"
      },
      "require": {
        "types": "./dist/core.d.cts",
        "default": "./dist/core.cjs"
      }
    },
    "./relations": {
      "import": {
        "types": "./dist/relations.d.ts",
        "default": "./dist/relations.js"
      },
      "require": {
        "types": "./dist/relations.d.cts",
        "default": "./dist/relations.cjs"
      }
    },
    "./tenant": {
      "import": {
        "types": "./dist/tenant-entry.d.ts",
        "default": "./dist/tenant-entry.js"
      },
      "require": {
        "types": "./dist/tenant-entry.d.cts",
        "default": "./dist/tenant-entry.cjs"
      }
    },
    "./observability": {
      "import": {
        "types": "./dist/observability-entry.d.ts",
        "default": "./dist/observability-entry.js"
      },
      "require": {
        "types": "./dist/observability-entry.d.cts",
        "default": "./dist/observability-entry.cjs"
      }
    },
    "./graphql": {
      "import": {
        "types": "./dist/graphql-entry.d.ts",
        "default": "./dist/graphql-entry.js"
      },
      "require": {
        "types": "./dist/graphql-entry.d.cts",
        "default": "./dist/graphql-entry.cjs"
      }
    },
    "./rest": {
      "import": {
        "types": "./dist/rest-entry.d.ts",
        "default": "./dist/rest-entry.js"
      },
      "require": {
        "types": "./dist/rest-entry.d.cts",
        "default": "./dist/rest-entry.cjs"
      }
    },
    "./plugins": {
      "import": {
        "types": "./dist/plugins-entry.d.ts",
        "default": "./dist/plugins-entry.js"
      },
      "require": {
        "types": "./dist/plugins-entry.d.cts",
        "default": "./dist/plugins-entry.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "espalier-jdbc": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.3"
  }
}
