{
  "name": "@espalier/next",
  "version": "1.2.0",
  "description": "Next.js App Router integration for Espalier — singleton DataSource, Server Component helpers, Server Action transactions",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "espalier-data": "workspace:*",
    "espalier-jdbc": "workspace:*",
    "next": ">=14.0.0"
  },
  "dependencies": {
    "espalier-data": "workspace:*",
    "espalier-jdbc": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.3"
  }
}
