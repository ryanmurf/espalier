{
  "name": "espalier-jdbc-libsql",
  "version": "1.6.0",
  "description": "LibSQL/Turso driver adapter for espalier-jdbc",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "espalier-jdbc": "workspace:*"
  },
  "peerDependencies": {
    "@libsql/client": ">=0.5.0"
  },
  "peerDependenciesMeta": {
    "@libsql/client": {
      "optional": false
    }
  },
  "devDependencies": {
    "@libsql/client": "^0.14.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.3"
  }
}
