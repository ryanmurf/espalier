{
  "name": "espalier-jdbc-d1",
  "version": "1.9.0",
  "description": "Cloudflare D1 driver adapter for espalier-jdbc",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "espalier-jdbc": "workspace:*"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241230.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.3"
  }
}
