{
  "name": "espalier-event-sourcing",
  "version": "2.0.0",
  "description": "Event sourcing and outbox pattern for Espalier",
  "license": "Apache-2.0",
  "author": "Ryan Murphy",
  "repository": {
    "type": "git",
    "url": "https://github.com/ryanmurf/espalier.git",
    "directory": "packages/event-sourcing"
  },
  "bugs": {
    "url": "https://github.com/ryanmurf/espalier/issues"
  },
  "homepage": "https://github.com/ryanmurf/espalier#readme",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./core": {
      "import": {
        "types": "./dist/core.d.ts",
        "default": "./dist/core.js"
      },
      "require": {
        "types": "./dist/core.d.cts",
        "default": "./dist/core.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "espalier-data": "workspace:*",
    "espalier-jdbc": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.7.3",
    "vitest": "^3.1.1"
  }
}
