{
  "name": "espalier-jdbc-sqlite",
  "version": "2.0.0",
  "description": "SQLite driver adapter for espalier-jdbc",
  "license": "Apache-2.0",
  "author": "Ryan Murphy",
  "repository": {
    "type": "git",
    "url": "https://github.com/ryanmurf/espalier.git",
    "directory": "packages/sqlite"
  },
  "bugs": {
    "url": "https://github.com/ryanmurf/espalier/issues"
  },
  "homepage": "https://github.com/ryanmurf/espalier#readme",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "espalier-jdbc": "workspace:*"
  },
  "peerDependencies": {
    "better-sqlite3": "^11.0.0"
  },
  "peerDependenciesMeta": {
    "better-sqlite3": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^11.7.0",
    "espalier-data": "workspace:*",
    "tsup": "^8.4.0",
    "typescript": "^5.7.3"
  }
}
