{
  "name": "espalier-testing",
  "version": "1.10.0",
  "description": "Testing utilities for espalier — entity factories, seeding, test isolation, and query assertions",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "espalier-data": "workspace:*",
    "espalier-jdbc": "workspace:*"
  },
  "peerDependenciesMeta": {
    "espalier-jdbc": {
      "optional": false
    },
    "espalier-data": {
      "optional": false
    }
  },
  "devDependencies": {
    "espalier-data": "workspace:*",
    "espalier-jdbc": "workspace:*",
    "espalier-jdbc-pg": "workspace:^",
    "tsup": "^8.4.0",
    "typescript": "^5.7.3"
  }
}
