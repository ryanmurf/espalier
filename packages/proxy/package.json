{
  "name": "espalier-proxy",
  "version": "2.0.0",
  "description": "Serverless connection proxy for espalier-jdbc — connection reuse across Lambda/edge invocations",
  "license": "Apache-2.0",
  "author": "Ryan Murphy",
  "repository": {
    "type": "git",
    "url": "https://github.com/ryanmurf/espalier.git",
    "directory": "packages/proxy"
  },
  "bugs": {
    "url": "https://github.com/ryanmurf/espalier/issues"
  },
  "homepage": "https://github.com/ryanmurf/espalier#readme",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "espalier-jdbc": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.3"
  }
}
