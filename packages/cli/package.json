{
  "name": "espalier-cli",
  "version": "1.2.0",
  "description": "CLI for Espalier database migrations and code generation",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "bin": {
    "espalier": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "espalier-data": "workspace:*",
    "espalier-jdbc": "workspace:*"
  },
  "peerDependencies": {
    "espalier-jdbc-pg": "workspace:*",
    "espalier-jdbc-mysql": "workspace:*",
    "espalier-jdbc-sqlite": "workspace:*"
  },
  "peerDependenciesMeta": {
    "espalier-jdbc-pg": { "optional": true },
    "espalier-jdbc-mysql": { "optional": true },
    "espalier-jdbc-sqlite": { "optional": true }
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "typescript": "^5.7.3",
    "tsup": "^8.4.0"
  }
}
